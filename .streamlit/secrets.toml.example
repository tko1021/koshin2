# Streamlit Community Cloud の Secrets 設定の形式（参考）。
# 実際に貼り付ける内容は、ローカルの secrets/streamlit_secrets.toml に自動生成済みです。
# （このファイルはあくまで形式の見本。実鍵は含みません）

app_password = "スタッフ用パスワード"

[gcp_service_account]
type = "service_account"
project_id = "koshin-dips-0188"
private_key_id = "（鍵ID）"
private_key = "-----BEGIN PRIVATE KEY-----\n（省略）\n-----END PRIVATE KEY-----\n"
client_email = "koshin-sheets@koshin-dips-0188.iam.gserviceaccount.com"
client_id = "（クライアントID）"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "（証明書URL）"
universe_domain = "googleapis.com"
